@model StockManagement.Models.Produit

<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="Nom" class="form-label fw-semibold"></label>
        <input asp-for="Nom" class="form-control" placeholder="Ex: Stylo bille" />
        <span asp-validation-for="Nom" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Reference" class="form-label fw-semibold"></label>
        <input asp-for="Reference" class="form-control" placeholder="Ex: REF-001" />
    </div>
    <div class="col-md-4">
        <label asp-for="Categorie" class="form-label fw-semibold"></label>
        <input asp-for="Categorie" class="form-control" placeholder="Ex: Informatique" list="categories" />
        <datalist id="categories">
            <option value="Informatique" />
            <option value="Fournitures" />
            <option value="Mobilier" />
            <option value="Électronique" />
            <option value="Autre" />
        </datalist>
    </div>
    <div class="col-md-4">
        <label asp-for="Quantite" class="form-label fw-semibold"></label>
        <div class="input-group">
            <input asp-for="Quantite" class="form-control" min="0" />
            <span class="input-group-text">unités</span>
        </div>
        <span asp-validation-for="Quantite" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="StockMinimum" class="form-label fw-semibold"></label>
        <div class="input-group">
            <input asp-for="StockMinimum" class="form-control" min="0" />
            <span class="input-group-text">unités</span>
        </div>
    </div>
    <div class="col-md-4">
        <label asp-for="Prix" class="form-label fw-semibold"></label>
        <div class="input-group">
            <input asp-for="Prix" class="form-control" step="0.01" min="0" />
            <span class="input-group-text">DH</span>
        </div>
        <span asp-validation-for="Prix" class="text-danger small"></span>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label fw-semibold"></label>
        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Description optionnelle..."></textarea>
    </div>
</div>
